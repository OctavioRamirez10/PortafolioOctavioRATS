---
import { basics } from "@cv";
import "../styles/theme.css";

interface Props {
  title: string
}

const { title } = Astro.props

const { image, summary, url } = basics
const cleanImage = image.startsWith('/') ? image.slice(1) : image;
const imageUrl = `${import.meta.env.BASE_URL}${cleanImage}`;
const faviconUrl = `${import.meta.env.BASE_URL}favicon.svg`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <meta name="description" content={summary} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={faviconUrl} />
    <link rel="preload" as="image" href={imageUrl} />

    <meta property="og:url" content={url} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={summary} />
    <meta property="og:image" content="" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:domain" content={url.split("//")[1] ?? ''} />
    <meta property="twitter:url" content={url} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={summary} />
    <meta name="twitter:image" content="" />
  </head>
  <body>
    <div class="page-wrapper">
      <slot />
    </div>
  </body>
</html>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');

  html {
    font-family: 'Plus Jakarta Sans', system-ui, -apple-system, sans-serif;
    background: #f8fafc;
    letter-spacing: -0.01em;
    color: #1e293b;
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    padding: 0;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .page-wrapper {
    max-width: 880px;
    margin: 28px auto;
    padding: 12px;
  }

  figure {
    margin: 0;
    padding: 0;
  }

  a {
    text-decoration: none;
    transition: all 0.2s ease;
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  h1,
  h2,
  h3,
  h4 {
    margin: 0;
    color: #0f172a;
    font-weight: 700;
  }

  p {
    color: #475569;
    font-size: 0.82rem;
    line-height: 1.5;
    margin: 0;
    text-wrap: pretty;
  }

  /* Tarjetas elegantes y espaciado de secciones */
  section {
    background: #ffffff;
    border: 1px solid #f1f5f9;
    border-radius: 12px;
    padding: 16px !important;
    box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.02), 0 1px 2px -1px rgba(0, 0, 0, 0.02);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    margin-bottom: 16px;
  }

  section:hover {
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -2px rgba(0, 0, 0, 0.05);
    border-color: #e2e8f0;
  }

  .print {
    display: none !important;
  }

  @media print {
    html {
      background: #fff;
      font-size: 11px;
    }

    body {
      min-height: auto;
    }

    section {
      background: transparent;
      border: none;
      box-shadow: none;
      padding: 0 !important;
      margin-bottom: 1.5rem;
    }

    section:hover {
      box-shadow: none;
      border: none;
    }

    .no-print {
      display: none !important;
    }

    .print {
      display: block !important;
    }

    astro-dev-toolbar {
      display: none !important;
    }

    article {
      break-inside: avoid;
    }
  }
</style>
